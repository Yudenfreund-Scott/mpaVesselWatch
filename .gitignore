# Virtual environment
.venv/

# Raw and processed AIS data (large, re-downloadable from NOAA MarineCadastre)
data/ais/
data/ais_ca/
data/ais_holdout/
data/mpa_pings/

# GFW registry (re-downloadable from Zenodo record 14982712)
data/gfw/

# Processed parquet files (regenerated by running the pipeline)
data/*.parquet

# Cached API responses
data/env_cache/

# Trained model binaries (regenerated by train_forecast.py)
models/*.pkl

# Temporary download files
data/tmp/
*.parquet.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# OS
.DS_Store
Thumbs.db

# Local Claude Code config
.claude/
